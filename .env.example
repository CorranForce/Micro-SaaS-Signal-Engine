# .env.example

# Gemini API key (required) — powers idea generation, launch kits, and chat
GEMINI_API_KEY=

# Optional Gemini model overrides. Defaults: gemini-2.5-flash / gemini-2.5-pro.
# Set these to the exact model IDs your API key has access to. Verify at
# https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=
GEMINI_MODEL_PRO=

# Secret used to sign session cookies and encrypt stored credentials.
# REQUIRED in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# (In dev, a random secret is auto-generated and persisted under data/.)
SESSION_SECRET=

# Email address allowed to manage API settings (defaults to the project owner)
OPERATOR_EMAIL=

# Resend Integration (launch-kit emails)
RESEND_API_KEY=
# Verified sender for real delivery, e.g. "SaaS Radar <radar@yourdomain.com>".
# The default onboarding@resend.dev sandbox sender only delivers to the
# Resend account owner's own address.
RESEND_FROM=

# Supabase Integration (Durable Cloud Persistence)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# GoDaddy Integration (Domain Registration checks)
GODADDY_API_KEY=
GODADDY_API_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret protecting the hourly cron route (/api/cron/agent).
# REQUIRED for the cron route to run — it fails closed (401) when unset.
# Vercel Cron automatically sends this as `Authorization: Bearer <CRON_SECRET>`.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
